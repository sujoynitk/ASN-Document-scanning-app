{
  "name": "asn-btp-app",
  "version": "1.0.0",
  "description": "ASN Co-packer Scanning BTP Application",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@cap-js/hana": "^2.8.0",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds": "^9.9.1",
    "@sap/xssec": "^4.13.0",
    "express": "^4",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.9.2"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch"
  },
  "cds": {
  "build": {
      "target": "gen",
      "tasks": [
        { "for": "hana" },
        { "for": "nodejs", "src": "srv", "options": { "model": ["db", "srv", "app"] } }
      ]
    },
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "admin": {
              "password": "admin"
            }
          }
        },
        "[production]": {
          "kind": "xsuaa"
        }
      }
    }
  }
}
